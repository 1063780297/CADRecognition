<Window x:Class="CADRecognition.TcpListEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="表格编辑"
        Width="1120"
        Height="780"
        Background="#1E1E1E"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.Resources>
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#2C4666"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="BorderBrush" Value="#7A93B0"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
            </Style>
        </Grid.Resources>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="TitleText"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"/>
            <TextBlock x:Name="HintText"
                       Margin="18,4,0,0"
                       Foreground="#9CDCFE"
                       Text="4列分别是 X、Y、位置模具编号、冲孔模具编号；支持插入、删除、复制、粘贴"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Content="插入行" Width="80" Margin="0,0,6,0" Click="InsertRow_Click"/>
                <Button Content="删除行" Width="80" Margin="0,0,6,0" Click="DeleteRow_Click"/>
                <Button Content="复制" Width="80" Margin="0,0,6,0" Click="Copy_Click"/>
                <Button Content="粘贴" Width="80" Click="Paste_Click"/>
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="GridView"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionUnit="CellOrRowHeader"
                  SelectionMode="Extended"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  Background="#0B1220"
                  Foreground="White"
                  RowBackground="#0F1722"
                  AlternatingRowBackground="#152131"
                  HorizontalGridLinesBrush="#2E415A"
                  VerticalGridLinesBrush="#2E415A"
                  BorderBrush="#4B5E78">
            <DataGrid.Columns>
                <DataGridTextColumn Header="行号" Binding="{Binding RowIndex}" IsReadOnly="True" Width="60"/>
                <DataGridTextColumn Header="X" Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Y" Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="位置模具编号" Binding="{Binding PositionMoldId, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="冲孔模具编号" Binding="{Binding PunchMoldId, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Width="96" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="确定" Width="96" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>