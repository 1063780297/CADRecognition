<Window x:Class="CADRecognition.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="模具拼接识别工作台"
        Height="780"
        Width="1400"
        MinHeight="640"
        MinWidth="1100"
        Background="#1E1E1E">
    <Window.Resources>
        <Style x:Key="HighContrastDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2C4666"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#6F88A6"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="HighContrastTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#1C2F46"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="420" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#2A2A2A" Padding="8" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <Button Content="导入工程图纸" Click="ImportProjectDxf_Click" Margin="0,0,6,0" />
                <Button Content="导入模具图纸(可多选)" Click="ImportMoldsDxf_Click" Margin="0,0,6,0" />
                <Button Content="一键识别匹配" Click="Recognize_Click" Margin="0,0,12,0" />
                <Button Content="导出" Click="Export_Click" Margin="0,0,6,0" />
                <TextBlock Text="板宽：" Foreground="#DDDDDD" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="BoardWidthTextBox"
                         Width="88"
                         Height="24"
                         Text="0"
                         VerticalContentAlignment="Center"
                         Margin="0,0,16,0"/>
                <CheckBox x:Name="CompactAnnoCheckBox"
                          Content="简洁标注"
                          IsChecked="False"
                          Checked="CompactAnnoCheckBox_Checked"
                          Unchecked="CompactAnnoCheckBox_Checked"
                          Foreground="#FFFFFF"
                          VerticalAlignment="Center"
                          Margin="0,0,20,0"/>
                <TextBlock Text="已加载工程：" Foreground="#DDDDDD" VerticalAlignment="Center" />
                <TextBlock x:Name="ProjectFileText" Foreground="#9CDCFE" VerticalAlignment="Center" Margin="4,0,20,0" />
                <TextBlock Text="模具数量：" Foreground="#DDDDDD" VerticalAlignment="Center" />
                <TextBlock x:Name="MoldCountText" Foreground="#9CDCFE" VerticalAlignment="Center" Margin="4,0,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Margin="0,10,10,10" Background="#252525" CornerRadius="4" Padding="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="工程/模具文件" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,6" />
                <TreeView x:Name="FileTreeView"
                          Background="#162235"
                          Foreground="#FFFFFF"
                          BorderBrush="#7C97B8"
                          ItemContainerStyle="{StaticResource HighContrastTreeViewItemStyle}"
                          MouseDoubleClick="FileTreeView_MouseDoubleClick"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Margin="0,10,10,10" Background="#111111" CornerRadius="4" BorderBrush="#3D3D3D" BorderThickness="1">
            <Grid>
                <ContentControl x:Name="PreviewHost" />
                <TextBlock x:Name="PreviewHintText"
                           Text="请先导入工程 DXF，随后可在此预览。"
                           Foreground="#707070"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="2" Margin="0,10,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#252525" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="模具清单" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,6" />
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="M01模具：" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="M01MoldComboBox" Width="220" Height="24"/>
                    </StackPanel>
                    <WrapPanel x:Name="LegendPanel" DockPanel.Dock="Top" Margin="0,0,0,8"/>
                    <DataGrid x:Name="MoldGrid"
                              ItemsSource="{Binding MoldRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="#0F1722"
                              AlternatingRowBackground="#152131"
                              Background="#0B1220"
                              Foreground="#FFFFFF"
                              HorizontalGridLinesBrush="#2E415A"
                              VerticalGridLinesBrush="#2E415A"
                              BorderBrush="#4B5E78"
                              ColumnHeaderStyle="{StaticResource HighContrastDataGridHeaderStyle}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="预览" Width="92">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="80" Height="52" Background="#111111" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="2" Padding="1">
                                            <Image Source="{Binding MoldPreview}" Stretch="Uniform"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding MoldCode}" Header="模具编号" Width="*"/>
                            <DataGridTextColumn Binding="{Binding MoldName}" Header="模具名称" Width="*"/>
                            <DataGridTextColumn Binding="{Binding UsedCount}" Header="使用次数" Width="80"/>
                            <DataGridTextColumn Binding="{Binding MatchType}" Header="匹配类型" Width="*"/>
                            <DataGridTextColumn Binding="{Binding Remark}" Header="备注" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Background="#252525" CornerRadius="4" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="孔位匹配明细" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,6" />
                    <DataGrid x:Name="PositionGrid"
                              ItemsSource="{Binding PositionRows}"
                              MouseLeftButtonUp="PositionGrid_MouseLeftButtonUp"
                              MouseDoubleClick="PositionGrid_MouseDoubleClick"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="#0F1722"
                              AlternatingRowBackground="#152131"
                              Background="#0B1220"
                              Foreground="#FFFFFF"
                              HorizontalGridLinesBrush="#2E415A"
                              VerticalGridLinesBrush="#2E415A"
                              BorderBrush="#4B5E78"
                              ColumnHeaderStyle="{StaticResource HighContrastDataGridHeaderStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Index}" Header="序号" Width="52"/>
                            <DataGridTextColumn Binding="{Binding HoleType}" Header="孔型" Width="96"/>
                            <DataGridTextColumn Binding="{Binding MoldCode}" Header="匹配模具" Width="78"/>
                            <DataGridTextColumn Binding="{Binding PosX}" Header="X" Width="82"/>
                            <DataGridTextColumn Binding="{Binding PosY}" Header="Y" Width="82"/>
                            <DataGridTextColumn Binding="{Binding IsCornerCandidate}" Header="角候选" Width="64" Visibility="Hidden"/>
                            <DataGridTextColumn Binding="{Binding IsEdgeHole}" Header="边缘孔" Width="64" Visibility="Hidden"/>
                            <DataGridTextColumn Binding="{Binding PositionRelation}" Header="位置关系" Width="120" Visibility="Hidden"/>
                            <DataGridTextColumn Binding="{Binding TopCandidates}" Header="Top3候选(面积比)" Width="260" Visibility="Hidden"/>
                            <DataGridTextColumn Binding="{Binding AreaRatio}" Header="选中面积比" Width="96" Visibility="Hidden"/>
                            <DataGridTextColumn Binding="{Binding FailureReason}" Header="失败原因" Width="320" Visibility="Hidden"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#2A2A2A" Padding="6" CornerRadius="4">
            <TextBlock x:Name="StatusText" Foreground="#DDDDDD" Text="就绪。" />
        </Border>
    </Grid>
</Window>