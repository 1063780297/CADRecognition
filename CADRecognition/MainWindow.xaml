<Window x:Class="CADRecognition.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="模具拼接识别工作台"
        Height="780"
        Width="1400"
        MinHeight="640"
        MinWidth="1100"
        Background="#1E1E1E">
    <Window.Resources>
        <Style x:Key="HighContrastDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2C4666"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#6F88A6"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="HighContrastTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#1C2F46"/>
            <Setter Property="Padding" Value="2"/>
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="520" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#2A2A2A" Padding="8" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <Button Content="导入工程图纸" Click="ImportProjectDxf_Click" Margin="0,0,15,0" />
                <Button Content="一键识别匹配" Click="Recognize_Click" Margin="0,0,15,0" />
                <Button Content="导出数据" Click="Export_Click" Margin="0,0,15,0" />
                <TextBlock Text="板宽：" Foreground="#DDDDDD" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="BoardWidthTextBox"
                         Width="88"
                         Height="24"
                         Text="0"
                         VerticalContentAlignment="Center"
                         Margin="0,0,16,0"
                         TextChanged="BoardWidthTextBox_TextChanged"/>
                <CheckBox x:Name="CompactAnnoCheckBox"
                          Content="简洁标注"
                          IsChecked="False"
                          Checked="CompactAnnoCheckBox_Checked"
                          Unchecked="CompactAnnoCheckBox_Checked"
                          Foreground="#FFFFFF"
                          VerticalAlignment="Center"
                          Margin="0,0,20,0"/>
                <TextBlock Text="已加载工程：" Foreground="#DDDDDD" VerticalAlignment="Center" />
                <TextBlock x:Name="ProjectFileText" Foreground="#9CDCFE" VerticalAlignment="Center" Margin="4,0,20,0" />
                <TextBlock Text="台1/台2：" Foreground="#DDDDDD" VerticalAlignment="Center" />
                <TextBlock x:Name="MoldCountText" Foreground="#9CDCFE" VerticalAlignment="Center" Margin="4,0,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Margin="0,10,10,10" Background="#252525" CornerRadius="4" Padding="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="工程/模具文件" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,6" />
                <TreeView x:Name="FileTreeView"
                          Background="#162235"
                          Foreground="#FFFFFF"
                          BorderBrush="#7C97B8"
                          ItemContainerStyle="{StaticResource HighContrastTreeViewItemStyle}"
                          MouseDoubleClick="FileTreeView_MouseDoubleClick"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Margin="0,10,10,10" Background="#111111" CornerRadius="4" BorderBrush="#3D3D3D" BorderThickness="1">
            <Grid>
                <ContentControl x:Name="PreviewHost" />
                <TextBlock x:Name="PreviewHintText"
                           Text="请先导入工程 DXF，随后可在此预览。"
                           Foreground="#707070"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="2" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="#252525" CornerRadius="4" Padding="8" Margin="0,0,4,8" Height="360">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="台1模具" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="导入模具" Click="ImportStage1MoldDxf_Click" HorizontalAlignment="Right" />
                    </Grid>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="模具选择" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="Stage1MoldComboBox" Width="190" Height="24" />
                    </StackPanel>
                    <WrapPanel x:Name="Stage1LegendPanel" DockPanel.Dock="Top" Margin="0,0,0,8"/>
                    <DataGrid x:Name="Stage1MoldGrid"
                              ItemsSource="{Binding Stage1MoldRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="#0F1722"
                              AlternatingRowBackground="#152131"
                              Background="#0B1220"
                              Foreground="#FFFFFF"
                              HorizontalGridLinesBrush="#2E415A"
                              VerticalGridLinesBrush="#2E415A"
                              BorderBrush="#4B5E78"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ColumnHeaderStyle="{StaticResource HighContrastDataGridHeaderStyle}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="预览" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="80" Height="52" Background="#111111" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="2" Padding="1">
                                            <Image Source="{Binding MoldPreview}" Stretch="Uniform"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding MoldCode}" Header="编号" Width="*"/>
                            <DataGridTextColumn Binding="{Binding MoldName}" Header="尺寸" Width="*"/>
                            <DataGridTextColumn Binding="{Binding UsedCount}" Header="次数" Width="*"/>
                            <DataGridTextColumn Binding="{Binding MatchType}" Header="匹配类型" Width="*" Visibility="Hidden"/>
                            <DataGridTextColumn Binding="{Binding Remark}" Header="备注" Width="*" Visibility="Hidden"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Background="#252525" CornerRadius="4" Padding="8" Margin="4,0,0,8" Height="360">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="台2模具" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="导入模具" Click="ImportStage2MoldDxf_Click" HorizontalAlignment="Right" />
                    </Grid>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="模具选择" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="Stage2MoldComboBox" Width="190" Height="24" />
                    </StackPanel>
                    <WrapPanel x:Name="Stage2LegendPanel" DockPanel.Dock="Top" Margin="0,0,0,8"/>
                    <DataGrid x:Name="Stage2MoldGrid"
                              ItemsSource="{Binding Stage2MoldRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="#0F1722"
                              AlternatingRowBackground="#152131"
                              Background="#0B1220"
                              Foreground="#FFFFFF"
                              HorizontalGridLinesBrush="#2E415A"
                              VerticalGridLinesBrush="#2E415A"
                              BorderBrush="#4B5E78"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ColumnHeaderStyle="{StaticResource HighContrastDataGridHeaderStyle}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="预览" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="80" Height="52" Background="#111111" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="2" Padding="1">
                                            <Image Source="{Binding MoldPreview}" Stretch="Uniform"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding MoldCode}" Header="编号" Width="*"/>
                            <DataGridTextColumn Binding="{Binding MoldName}" Header="尺寸" Width="*"/>
                            <DataGridTextColumn Binding="{Binding UsedCount}" Header="次数" Width="*"/>
                            <DataGridTextColumn Binding="{Binding MatchType}" Header="匹配类型" Width="*" Visibility="Hidden"/>
                            <DataGridTextColumn Binding="{Binding Remark}" Header="备注" Width="*" Visibility="Hidden"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#252525" CornerRadius="4" Padding="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <DockPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock DockPanel.Dock="Top" Text="台1孔位" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,6" />
                        <DataGrid x:Name="PositionGrid"
                                  ItemsSource="{Binding Stage1PositionRows}"
                                  MouseLeftButtonUp="PositionGrid_MouseLeftButtonUp"
                                  MouseDoubleClick="PositionGrid_MouseDoubleClick"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowBackground="#0F1722"
                                  AlternatingRowBackground="#152131"
                                  Background="#0B1220"
                                  Foreground="#FFFFFF"
                                  HorizontalGridLinesBrush="#2E415A"
                                  VerticalGridLinesBrush="#2E415A"
                                  BorderBrush="#4B5E78"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ColumnHeaderStyle="{StaticResource HighContrastDataGridHeaderStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Index}" Header="序号" Width="*"/>
                                <DataGridTextColumn Binding="{Binding HoleType}" Header="孔型" Width="2*" Visibility="Hidden"/>
                                <DataGridTextColumn Binding="{Binding MoldCode}" Header="模具" Width="*"/>
                                <DataGridTextColumn Binding="{Binding PosX}" Header="X" Width="*"/>
                                <DataGridTextColumn Binding="{Binding PosY}" Header="Y" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                    <DockPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock DockPanel.Dock="Top" Text="台2孔位" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,6" />
                        <DataGrid x:Name="Stage2PositionGrid"
                                  ItemsSource="{Binding Stage2PositionRows}"
                                  MouseLeftButtonUp="PositionGrid_MouseLeftButtonUp"
                                  MouseDoubleClick="PositionGrid_MouseDoubleClick"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowBackground="#0F1722"
                                  AlternatingRowBackground="#152131"
                                  Background="#0B1220"
                                  Foreground="#FFFFFF"
                                  HorizontalGridLinesBrush="#2E415A"
                                  VerticalGridLinesBrush="#2E415A"
                                  BorderBrush="#4B5E78"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ColumnHeaderStyle="{StaticResource HighContrastDataGridHeaderStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Index}" Header="序号" Width="*"/>
                                <DataGridTextColumn Binding="{Binding HoleType}" Header="孔型" Width="2*" Visibility="Hidden"/>
                                <DataGridTextColumn Binding="{Binding MoldCode}" Header="模具" Width="*"/>
                                <DataGridTextColumn Binding="{Binding PosX}" Header="X" Width="*"/>
                                <DataGridTextColumn Binding="{Binding PosY}" Header="Y" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#2A2A2A" Padding="6" CornerRadius="4">
            <TextBlock x:Name="StatusText" Foreground="#DDDDDD" Text="就绪。" />
        </Border>
    </Grid>
</Window>