<Window x:Class="CADRecognition.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        mc:Ignorable="d"
        Title="模具拼接识别工作台"
        Height="780"
        Width="1400"
        MinHeight="640"
        MinWidth="1100"
        Background="#1E1E1E">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="420" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#2A2A2A" Padding="8" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <Button Content="导入工程 DXF(2010)" Click="ImportProjectDxf_Click" Margin="0,0,6,0" />
                <Button Content="导入模具 DXF(可多选)" Click="ImportMoldsDxf_Click" Margin="0,0,6,0" />
                <Button Content="一键识别匹配" Click="Recognize_Click" Margin="0,0,20,0" />
                <TextBlock Text="已加载工程：" Foreground="#DDDDDD" VerticalAlignment="Center" />
                <TextBlock x:Name="ProjectFileText" Foreground="#9CDCFE" VerticalAlignment="Center" Margin="4,0,20,0" />
                <TextBlock Text="模具数量：" Foreground="#DDDDDD" VerticalAlignment="Center" />
                <TextBlock x:Name="MoldCountText" Foreground="#9CDCFE" VerticalAlignment="Center" Margin="4,0,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Margin="0,10,10,10" Background="#252525" CornerRadius="4" Padding="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="工程/模具文件" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,6" />
                <TreeView x:Name="FileTreeView"
                          Background="#1F1F1F"
                          Foreground="#DDDDDD"
                          BorderBrush="#3D3D3D"
                          MouseDoubleClick="FileTreeView_MouseDoubleClick"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Margin="0,10,10,10" Background="#111111" CornerRadius="4" BorderBrush="#3D3D3D" BorderThickness="1">
            <Grid>
                <ContentControl x:Name="PreviewHost" />
                <TextBlock x:Name="PreviewHintText"
                           Text="请先导入工程 DXF，随后可在此预览。"
                           Foreground="#707070"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="2" Margin="0,10,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#252525" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="模具清单" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,6" />
                    <WrapPanel x:Name="LegendPanel" DockPanel.Dock="Top" Margin="0,0,0,8"/>
                    <dxg:GridControl x:Name="MoldGrid" ItemsSource="{Binding MoldRows}">
                        <dxg:GridControl.View>
                            <dxg:TableView ShowGroupPanel="False" AutoWidth="True" AllowEditing="False"/>
                        </dxg:GridControl.View>
                        <dxg:GridControl.Columns>
                            <dxg:GridColumn FieldName="MoldPreview" Header="预览" Width="92">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="80" Height="52" Background="#111111" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="2" Padding="1">
                                            <Image Source="{Binding RowData.Row.MoldPreview}" Stretch="Uniform"/>
                                        </Border>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="MoldCode" Header="模具编号"/>
                            <dxg:GridColumn FieldName="MoldName" Header="模具名称"/>
                            <dxg:GridColumn FieldName="UsedCount" Header="使用次数"/>
                            <dxg:GridColumn FieldName="MatchType" Header="匹配类型"/>
                            <dxg:GridColumn FieldName="Remark" Header="备注"/>
                        </dxg:GridControl.Columns>
                    </dxg:GridControl>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Background="#252525" CornerRadius="4" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="孔位匹配明细" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,6" />
                    <dxg:GridControl x:Name="PositionGrid"
                                     ItemsSource="{Binding PositionRows}"
                                     MouseLeftButtonUp="PositionGrid_MouseLeftButtonUp"
                                     MouseDoubleClick="PositionGrid_MouseDoubleClick">
                        <dxg:GridControl.View>
                            <dxg:TableView ShowGroupPanel="False" AutoWidth="False" AllowEditing="False"/>
                        </dxg:GridControl.View>
                        <dxg:GridControl.Columns>
                            <dxg:GridColumn FieldName="Index" Header="序号" Width="52"/>
                            <dxg:GridColumn FieldName="HoleType" Header="孔型" Width="96"/>
                            <dxg:GridColumn FieldName="MoldCode" Header="匹配模具" Width="78"/>
                            <dxg:GridColumn FieldName="PosX" Header="X" Width="82"/>
                            <dxg:GridColumn FieldName="PosY" Header="Y" Width="82"/>
                            <dxg:GridColumn FieldName="IsCornerCandidate" Header="角候选" Width="64"/>
                            <dxg:GridColumn FieldName="IsEdgeHole" Header="边缘孔" Width="64"/>
                            <dxg:GridColumn FieldName="PositionRelation" Header="位置关系" Width="120"/>
                            <dxg:GridColumn FieldName="TopCandidates" Header="Top3候选(面积比)" Width="260"/>
                            <dxg:GridColumn FieldName="AreaRatio" Header="选中面积比" Width="96"/>
                            <dxg:GridColumn FieldName="FailureReason" Header="失败原因" Width="320"/>
                        </dxg:GridControl.Columns>
                    </dxg:GridControl>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#2A2A2A" Padding="6" CornerRadius="4">
            <TextBlock x:Name="StatusText" Foreground="#DDDDDD" Text="就绪。" />
        </Border>
    </Grid>
</Window>