<Window x:Class="CADRecognition.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        xmlns:local="clr-namespace:CADRecognition"
        mc:Ignorable="d"
        Title="模具拼接识别工作台" Height="720" Width="1280" MinHeight="600" MinWidth="1000"
        FontFamily="Segoe UI" FontSize="12">
    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="Brush.Window" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="Brush.TopBar" Color="#FF242424"/>
        <SolidColorBrush x:Key="Brush.Panel" Color="#FF252525"/>
        <SolidColorBrush x:Key="Brush.Panel2" Color="#FF2A2A2A"/>
        <SolidColorBrush x:Key="Brush.Canvas" Color="#FF101010"/>
        <SolidColorBrush x:Key="Brush.Border" Color="#FF3A3A3A"/>
        <SolidColorBrush x:Key="Brush.BorderSoft" Color="#FF333333"/>
        <SolidColorBrush x:Key="Brush.Text" Color="#FFE6E6E6"/>
        <SolidColorBrush x:Key="Brush.TextMuted" Color="#FFB8B8B8"/>
        <SolidColorBrush x:Key="Brush.Accent" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="Brush.Hover" Color="#FF3A3A3A"/>
        <SolidColorBrush x:Key="Brush.Pressed" Color="#FF444444"/>
        <SolidColorBrush x:Key="Brush.Tool" Color="#FF2B2B2B"/>

        <!-- Default Button -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.Hover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.Pressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tool Button base style (used by DevExpress buttons) -->
        <Style x:Key="ToolButtonBaseStyle" TargetType="Control">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- Section Header -->
        <Style x:Key="SectionHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Background="#FF1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <DockPanel Grid.Row="0" Background="#FF2B2B2B" Height="64">
            <!-- 左侧产品名 -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="12,0,24,0" VerticalAlignment="Center">
                <Border Width="28" Height="28" CornerRadius="4" Background="#FF4CAF50" Margin="0,0,8,0">
                    <TextBlock Text="M" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="模具拼接识别工作台" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Mold DXF Studio" Foreground="#FFAAAAAA" FontSize="11"/>
                </StackPanel>
            </StackPanel>

            <!-- 中间功能分组 -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">
                <StackPanel Orientation="Vertical" Margin="0,4">
                    <TextBlock Text="文件" Foreground="White" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="导入模具 DXF"/>
                        <Button Content="导入工程 DXF"/>
                        <Button Content="导出识别报告"/>
                    </StackPanel>
                </StackPanel>
                
                <Separator Margin="8" VerticalAlignment="Stretch" Width="1" Background="#FF444444"/>
                <StackPanel Orientation="Vertical" Margin="0,4">
                    <TextBlock Text="绘制" Foreground="White" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="直线"/>
                        <Button Content="多段线"/>
                        <Button Content="矩形"/>
                        <Button Content="圆"/>
                    </StackPanel>
                </StackPanel>
                <Separator Margin="8" VerticalAlignment="Stretch" Width="1" Background="#FF444444"/>
                <StackPanel Orientation="Vertical" Margin="0,4">
                    <TextBlock Text="识别与匹配" Foreground="White" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="一键识别工程图"/>
                        <Button Content="刷新匹配结果"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- 右侧工程选择 / 用户 -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="0,0,12,0" VerticalAlignment="Center">
                <ComboBox Width="180" Margin="0,0,12,0" SelectedIndex="0">
                    <ComboBoxItem Content="工程 A"/>
                    <ComboBoxItem Content="工程 B"/>
                </ComboBox>
                <Border Width="32" Height="32" CornerRadius="16" Background="#FF555555">
                    <TextBlock Text="U" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </DockPanel>

        <!-- 中间三栏 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- 左：工程管理 + 图层 -->
            <Grid Grid.Column="0" Background="#FF252525">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 工程管理 -->
                <Border Grid.Row="0" BorderBrush="#FF3A3A3A" BorderThickness="0,0,1,1" Padding="8">
                    <DockPanel>
                        <TextBlock Text="工程管理" Style="{StaticResource SectionHeaderText}" DockPanel.Dock="Top"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,6,0,4">
                            <Button Content="导入工程 DXF"/>
                            <Button Content="导入模具 DXF"/>
                            <Button Content="刷新"/>
                        </StackPanel>
                        <TreeView Margin="0,4,0,0" Background="#FF2A2A2A" Foreground="#FFDDDDDD">
                            <TreeViewItem Header="工程 A - 模具拼接方案" IsExpanded="True">
                                <TreeViewItem Header="工程图纸.dxf"/>
                                <TreeViewItem Header="模具库">
                                    <TreeViewItem Header="模具 A.dxf"/>
                                    <TreeViewItem Header="模具 B.dxf"/>
                                    <TreeViewItem Header="模具 C.dxf"/>
                                </TreeViewItem>
                            </TreeViewItem>
                        </TreeView>
                    </DockPanel>
                </Border>                
            </Grid>

            <!-- 中：CAD 画布区域 -->
            <Grid Grid.Column="1" Background="#FF1E1E1E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 视图工具条 -->
                <DockPanel Grid.Row="0" Background="#FF2B2B2B" Height="32">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="8,0">
                        <Button Content="放大"/>
                        <Button Content="缩小"/>
                        <Button Content="适应窗口"/>
                        <Separator Margin="8,4" Width="1" Background="#FF444444"/>
                        <CheckBox Content="显示网格" Margin="4,0" Foreground="White" VerticalAlignment="Center"/>
                        <CheckBox Content="捕捉端点" Margin="4,0" Foreground="White" VerticalAlignment="Center"/>
                        <CheckBox Content="捕捉中点" Margin="4,0" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>

                <!-- 画布 + 工具栏 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧 CAD 风格矢量线条工具栏 -->
                    <Border Grid.Column="0" Background="#FF2B2B2B" BorderBrush="#FF3A3A3A" BorderThickness="0,1,1,0">
                        <StackPanel Orientation="Vertical" Margin="4">
                            <!-- 选择 -->
                            <Button ToolTip="选择" Style="{StaticResource ToolButtonBaseStyle}">
                                <Canvas Width="24" Height="24">
                                    <Polygon Points="4,4 18,10 11,13 13,20" Stroke="#FF000000" StrokeThickness="1.8" Fill="Transparent" StrokeLineJoin="Round"/>
                                </Canvas>
                            </Button>
                            <!-- 直线 -->
                            <Button ToolTip="直线" Style="{StaticResource ToolButtonBaseStyle}">
                                <Canvas Width="24" Height="24">
                                    <Line X1="4" Y1="18" X2="20" Y2="6" Stroke="#FF000000" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Button>
                            <!-- 多段线 -->
                            <Button ToolTip="多段线" Style="{StaticResource ToolButtonBaseStyle}">
                                <Canvas Width="24" Height="24">
                                    <Polyline Points="4,18 10,8 16,18 22,8" Stroke="#FF000000" StrokeThickness="2.0" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Button>
                            <!-- 矩形 -->
                            <Button ToolTip="矩形" Style="{StaticResource ToolButtonBaseStyle}">
                                <Canvas Width="24" Height="24">
                                    <Rectangle Width="18" Height="12" Canvas.Left="3" Canvas.Top="6" Stroke="#FF000000" StrokeThickness="2.0" RadiusX="1" RadiusY="1"/>
                                </Canvas>
                            </Button>
                            <!-- 圆 -->
                            <Button ToolTip="圆" Style="{StaticResource ToolButtonBaseStyle}">
                                <Canvas Width="24" Height="24">
                                    <Ellipse Width="16" Height="16" Canvas.Left="4" Canvas.Top="4" Stroke="#FF000000" StrokeThickness="2.0"/>
                                </Canvas>
                            </Button>

                            <Separator Margin="0,10" Background="#FF444444"/>

                            <!-- 测量 -->
                            <Button ToolTip="测量" Style="{StaticResource ToolButtonBaseStyle}">
                                <Canvas Width="24" Height="24">
                                    <Line X1="4" Y1="16" X2="20" Y2="16" Stroke="#FF000000" StrokeThickness="2.0" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="4" Y1="16" X2="8" Y2="12" Stroke="#FF000000" StrokeThickness="2.0"/>
                                    <Line X1="4" Y1="16" X2="8" Y2="20" Stroke="#FF000000" StrokeThickness="2.0"/>
                                    <Line X1="20" Y1="16" X2="16" Y2="12" Stroke="#FF000000" StrokeThickness="2.0"/>
                                    <Line X1="20" Y1="16" X2="16" Y2="20" Stroke="#FF000000" StrokeThickness="2.0"/>
                                </Canvas>
                            </Button>
                            <!-- 移动 -->
                            <Button ToolTip="移动" Style="{StaticResource ToolButtonBaseStyle}">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="#FF000000" StrokeThickness="1.8" StrokeLineJoin="Round" Fill="Transparent"
                                          Data="M12,4 L9,8 L11,8 L11,11 L8,11 L8,9 L4,12 L8,15 L8,13 L11,13 L11,16 L9,16 L12,20 L15,16 L13,16 L13,13 L16,13 L16,15 L20,12 L16,9 L16,11 L13,11 L13,8 L15,8 Z"/>
                                </Canvas>
                            </Button>
                            <!-- 旋转 -->
                            <Button ToolTip="旋转" Style="{StaticResource ToolButtonBaseStyle}">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="#FF000000" StrokeThickness="2.0" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M6,14 A6,6 0 1 1 18,10"/>
                                    <Polyline Points="16,6 18,10 20,6" Stroke="#FF000000" StrokeThickness="2.0" StrokeLineJoin="Round"/>
                                </Canvas>
                            </Button>
                            <!-- 缩放 -->
                            <Button ToolTip="缩放" Style="{StaticResource ToolButtonBaseStyle}">
                                <Canvas Width="24" Height="24">
                                    <Rectangle Width="12" Height="12" Canvas.Left="4" Canvas.Top="4" Stroke="#FF000000" StrokeThickness="1.8"/>
                                    <Line X1="14" Y1="14" X2="20" Y2="20" Stroke="#FF000000" StrokeThickness="2.0" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="16" Y1="18" X2="18" Y2="16" Stroke="#FF000000" StrokeThickness="2.0"/>
                                </Canvas>
                            </Button>
                            <!-- 镜像 -->
                            <Button ToolTip="镜像" Style="{StaticResource ToolButtonBaseStyle}">
                                <Canvas Width="24" Height="24">
                                    <Line X1="12" Y1="4" X2="12" Y2="20" Stroke="#FF000000" StrokeThickness="1.6" StrokeDashArray="2 2"/>
                                    <Polyline Points="8,6 5,12 8,18" Stroke="#FF000000" StrokeThickness="2.0" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Polyline Points="16,6 19,12 16,18" Stroke="#FF000000" StrokeThickness="2.0" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.7"/>
                                </Canvas>
                            </Button>
                            <!-- 删除 -->
                            <Button ToolTip="删除" Style="{StaticResource ToolButtonBaseStyle}">
                                <Canvas Width="24" Height="24">
                                    <Rectangle Width="14" Height="14" Canvas.Left="5" Canvas.Top="6" Stroke="#FF000000" StrokeThickness="1.6"/>
                                    <Line X1="8" Y1="9" X2="16" Y2="17" Stroke="#FF000000" StrokeThickness="2.0" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="16" Y1="9" X2="8" Y2="17" Stroke="#FF000000" StrokeThickness="2.0" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 画布占位 -->
                    <Border Grid.Column="1" Margin="4" Background="#FF111111" BorderBrush="#FF3A3A3A" BorderThickness="1">
                        <Grid>
                            <Canvas>
                                <Line X1="0" Y1="120" X2="500" Y2="120" Stroke="#FF555555" StrokeThickness="1" StrokeDashArray="4 4"/>
                                <Line X1="260" Y1="0" X2="260" Y2="320" Stroke="#FF555555" StrokeThickness="1" StrokeDashArray="4 4"/>
                                <TextBlock Text="DXF 预览 / 编辑画布区域" Foreground="#FF777777" FontSize="16" Canvas.Left="40" Canvas.Top="40"/>
                            </Canvas>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 右：模具清单 + 位置明细 -->
            <Grid Grid.Column="2" Background="#FF252525">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 模具清单 -->
                <Border Grid.Row="0" BorderBrush="#FF3A3A3A" BorderThickness="1,0,0,1" Padding="8">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="模具清单" Style="{StaticResource SectionHeaderText}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,4">
                                <TextBox Width="150" Margin="0,0,6,0" Padding="4" Text="搜索模具编号/名称"/>
                                <ComboBox Width="80" Margin="0,0,6,0" SelectedIndex="0">
                                    <ComboBoxItem Content="全部"/>
                                    <ComboBoxItem Content="已使用"/>
                                    <ComboBoxItem Content="未使用"/>
                                </ComboBox>
                                <Button Content="刷新识别" Padding="6,2"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 模具清单表格：DevExpress GridControl -->
                        <dxg:GridControl Margin="0,4,0,0">
                            <dxg:GridControl.View>
                                <dxg:TableView ShowGroupPanel="False" AutoWidth="True" AllowEditing="False" />
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn FieldName="MoldCode" Header="模具编号" Width="*"/>
                                <dxg:GridColumn FieldName="MoldName" Header="模具名称" Width="*"/>
                                <dxg:GridColumn FieldName="UsedCount" Header="工程用量" Width="*"/>
                                <dxg:GridColumn FieldName="MatchType" Header="匹配类型" Width="*"/>
                                <dxg:GridColumn FieldName="Remark" Header="备注" Width="*"/>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>
                    </DockPanel>
                </Border>

                <!-- 位置明细 -->
                <Border Grid.Row="1" BorderBrush="#FF3A3A3A" BorderThickness="1,1,0,0" Padding="8">
                    <DockPanel>
                        <TextBlock Text="位置明细" Style="{StaticResource SectionHeaderText}" DockPanel.Dock="Top"/>
                        <!-- 位置明细表格：DevExpress GridControl -->
                        <dxg:GridControl Margin="0,4,0,0">
                            <dxg:GridControl.View>
                                <dxg:TableView ShowGroupPanel="False" AutoWidth="True" AllowEditing="False" />
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn FieldName="Index" Header="序号" Width="*"/>
                                <dxg:GridColumn FieldName="ViewName" Header="所在视图" Width="*"/>
                                <dxg:GridColumn FieldName="PosX" Header="X 坐标" Width="*"/>
                                <dxg:GridColumn FieldName="PosY" Header="Y 坐标" Width="*"/>
                                <dxg:GridColumn FieldName="RotationDeg" Header="旋转角度(°)" Width="*"/>
                                <dxg:GridColumn FieldName="IsMirrored" Header="是否镜像" Width="*"/>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="#FF2B2B2B" BorderBrush="#FF3A3A3A" BorderThickness="0,1,0,0">
            <DockPanel Margin="8,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="坐标: X=0.00, Y=0.00" Foreground="#FFCCCCCC" Margin="0,0,16,0"/>
                    <TextBlock Text="捕捉: 端点, 中点" Foreground="#FFAAAAAA" Margin="0,0,16,0"/>
                    <TextBlock Text="图层: 0" Foreground="#FFAAAAAA" Margin="0,0,16,0"/>
                    <TextBlock Text="单位: mm" Foreground="#FFAAAAAA" Margin="0,0,16,0"/>
                    <TextBlock Text="缩放: 100%" Foreground="#FFAAAAAA"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="就绪" Foreground="#FFAAAAAA" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>