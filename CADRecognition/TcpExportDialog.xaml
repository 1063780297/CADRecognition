<Window x:Class="CADRecognition.TcpExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="导出数据"
        Width="1360"
        Height="860"
        Background="#F3F0E8"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="SimSun"/>
            <Setter Property="Foreground" Value="#111111"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="SimSun"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="SimSun"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="IsEditable" Value="True"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E7E1D6"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontFamily" Value="SimSun"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#999999"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="FontFamily" Value="SimSun"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="BorderBrush" Value="#B0B0B0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF8C00" BorderBrush="#333333" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="数据名称" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                <TextBlock Grid.Column="1" Text="程序名" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#5F5F5F" BorderThickness="1" Background="#FAF7EF" Margin="0,0,6,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="图纸名" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="10,6,0,6" FontWeight="Bold"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="ProgramNameTextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="程序号" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="ProgramNoTextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="左右门" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="LeftRightDoorTextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="材质" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="MaterialTextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="类型" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TypeTextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="成型长" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="FormingLengthTextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="成型宽" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="6" Grid.Column="1" x:Name="FormingWidthTextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="成型厚" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="7" Grid.Column="1" x:Name="FormingThicknessTextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="台1冲孔次数" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="8" Grid.Column="1" x:Name="Stage1PunchCountTextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="9" Grid.Column="0" Text="台2冲孔次数" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="9" Grid.Column="1" x:Name="Stage2PunchCountTextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="10" Grid.Column="0" Text="备用2" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="10" Grid.Column="1" x:Name="Spare2TextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="11" Grid.Column="0" Text="板长" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="11" Grid.Column="1" x:Name="PlateLengthTextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="12" Grid.Column="0" Text="板宽" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="12" Grid.Column="1" x:Name="PlateWidthTextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="13" Grid.Column="0" Text="板厚" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="13" Grid.Column="1" x:Name="PlateThicknessTextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="14" Grid.Column="0" Text="备用3" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="14" Grid.Column="1" x:Name="Spare3TextBox" Margin="4,4,10,4"/>
                    <TextBlock Grid.Row="15" Grid.Column="0" Text="备用4" VerticalAlignment="Center" Margin="10,6,0,6"/>
                    <TextBox Grid.Row="15" Grid.Column="1" x:Name="Spare4TextBox" Margin="4,4,10,4"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderBrush="#5F5F5F" BorderThickness="1" Background="White">
                <TabControl x:Name="StageTabControl">
                    <TabItem Header="台1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!--<StackPanel Orientation="Horizontal" Margin="4">
                                <Button Content="插入" Width="64" Margin="0,0,6,0" Click="Stage1Insert_Click"/>
                                <Button Content="删除" Width="64" Margin="0,0,6,0" Click="Stage1Delete_Click"/>
                                <Button Content="复制" Width="64" Margin="0,0,6,0" Click="Stage1Copy_Click"/>
                                <Button Content="粘贴" Width="64" Click="Stage1Paste_Click"/>
                            </StackPanel>-->
                            <DataGrid x:Name="Stage1Grid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F7F7F7"
                                      Background="White"
                                      Foreground="#111111"
                                      BorderThickness="0"
                                      IsReadOnly="False"
                                      SelectionMode="Single"
                                      SelectionUnit="CellOrRowHeader"
                                      PreviewKeyDown="Stage1Grid_PreviewKeyDown">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="序号" Binding="{Binding RowIndex}" IsReadOnly="True" Width="64"/>
                                    <DataGridTextColumn Header="X" Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="Y" Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="位置模具编号" Binding="{Binding PositionMoldId, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="冲孔模具编号" Binding="{Binding PunchMoldId, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="台2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!--<StackPanel Orientation="Horizontal" Margin="4">
                                <Button Content="插入" Width="64" Margin="0,0,6,0" Click="Stage2Insert_Click"/>
                                <Button Content="删除" Width="64" Margin="0,0,6,0" Click="Stage2Delete_Click"/>
                                <Button Content="复制" Width="64" Margin="0,0,6,0" Click="Stage2Copy_Click"/>
                                <Button Content="粘贴" Width="64" Click="Stage2Paste_Click"/>
                            </StackPanel>-->
                            <DataGrid x:Name="Stage2Grid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F7F7F7"
                                      Background="White"
                                      Foreground="#111111"
                                      BorderThickness="0"
                                      IsReadOnly="False"
                                      SelectionMode="Single"
                                      SelectionUnit="CellOrRowHeader"
                                      PreviewKeyDown="Stage2Grid_PreviewKeyDown">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="序号" Binding="{Binding RowIndex}" IsReadOnly="True" Width="64"/>
                                    <DataGridTextColumn Header="X" Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="Y" Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="位置模具编号" Binding="{Binding PositionMoldId, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="冲孔模具编号" Binding="{Binding PunchMoldId, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FF8C00" BorderBrush="#333333" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Grid.Column="0" Text="数据准备就绪"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock Text="主机" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="TcpHostComboBox" Width="140" Height="22" IsEditable="True"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="端口" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="TcpPortComboBox" Width="54" Height="22" IsEditable="True"/>
                </StackPanel>
                <Button Grid.Column="5" Content="调用" Width="80" Margin="4,2" Click="Export_Click" Visibility="Hidden"/>
                <Button Grid.Column="6" Content="发送" Width="80" Margin="4,2" Click="SendTcp_Click"/>
                <Button Grid.Column="7" Content="取消" Width="80" Margin="4,2" Click="Cancel_Click"/>
                <Button Grid.Column="8" Content="关闭" Width="80" Margin="4,2" Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>